# Variables de entorno del proyecto
# Copiar este archivo a .env y completar con valores reales
# NUNCA versionar el archivo .env

# Google Gemini API Key (requerido para procesamiento IA)
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Apify API Key (requerido para extracción de transcripciones de YouTube)
# Obtener en: https://console.apify.com/account/integrations
APIFY_API_KEY=your-apify-api-key-here

# Puerto del servidor (opcional, default: 3000)
# PORT=3000
